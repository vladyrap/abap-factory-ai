# ─── Copia a .env.prod y completa. NUNCA subas .env.prod al repo. ───
SECRET_KEY=genera-una-cadena-larga-y-aleatoria
APP_PUBLIC_URL=https://abapfactory.tudominio.cl
CORS_ORIGINS=["https://abapfactory.tudominio.cl"]

# PostgreSQL (el host es 'db' dentro de la red de Docker)
POSTGRES_USER=abap
POSTGRES_PASSWORD=cambia-esta-clave-fuerte
POSTGRES_DB=abap_factory

# IA — al menos una. Claves SOLO aquí (entorno), nunca en código.
DEFAULT_AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-opus-4-8
OPENAI_DEFAULT_MODEL=gpt-4o
USD_TO_CLP=950
