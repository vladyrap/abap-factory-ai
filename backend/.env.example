# ─── App ───────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria
APP_PUBLIC_URL=http://localhost:6600
CORS_ORIGINS=["http://localhost:6600","http://localhost:5173"]

# ─── PostgreSQL (puertos propios para no chocar con otros proyectos) ─────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abap_factory
POSTGRES_HOST=localhost
POSTGRES_PORT=6602

# ─── IA — conmutable. Configura al menos una. NUNCA subas este archivo lleno. ─
DEFAULT_AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-opus-4-8
OPENAI_DEFAULT_MODEL=gpt-4o

# Tipo de cambio para reportar costos en CLP
USD_TO_CLP=950
